# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/ranked.db

# Auth secrets (GENERATE STRONG RANDOM VALUES — DO NOT COMMIT REAL VALUES)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-64-bytes-of-random-hex
JWT_REFRESH_SECRET=replace-me-with-different-64-bytes-of-random-hex
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# HMAC key shared with the Fabric mod for authenticating game-end POSTs
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MOD_HMAC_KEY=replace-me-with-shared-secret-also-set-in-mod-config

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
